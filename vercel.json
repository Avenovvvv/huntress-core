{
  "cleanUrls": true,

  "headers": [
    {
      "source": "/(.*)",
      "headers": [

        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },

        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },

        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },

        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },

        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },

        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; img-src 'self' https: data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'; object-src 'none'; base-uri 'self'; form-action 'self' https://docs.google.com https://formspree.io;"
        }

      ]
    }
  ]
}
